        public void CheckMRPFailed()
        {
            try 
            {
            	repo.RanorexRT2PLMMainForm.StatusEqApprovalPendingInfo.WaitForExists(180000);
            	Report.Log(ReportLevel.Info, "Found Status equals Approval Pending");
            } 
            catch (Exception) 
            {
            	
            	if (repo.RanorexRT2PLMMainForm.StatusMRPFailedInfo.Exists())
            	{
            		int i=0;
            		do
            		{
            			Report.Log(ReportLevel.Info, "Received Failed To Validate MRP Project, retrying...");
            			repo.RanorexRT2PLMMainForm.Approve.Click();
            			repo.RanorexRT2PLMMainForm.StatusEqApprovalPendingInfo.WaitForExists(180000);
            			i++;
            		}while(repo.RanorexRT2PLMMainForm.StatusMRPFailedInfo.Exists()&&i<3);
            	}
            		
            }
        }

        public void RefreshandCheck()
        {
        	if(!repo.RanorexRT2PLMMainForm.ReqNametoApproveRanorexRT2Info.Exists(30000))
        	{
        		int i=0;
        		do
