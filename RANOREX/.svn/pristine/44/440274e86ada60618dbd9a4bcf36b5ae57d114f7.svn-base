        			Report.Log(ReportLevel.Info, "Did not find Req: " + varReqName + " Pressing Refresh...");
        			repo.RanorexRT2PLMMainForm.Copy_of_AbstractThreadedPanelDollarRefreshButton.Click();
        			Delay.Seconds(30.0);
        			i++;
        		
        		}while(!repo.RanorexRT2PLMMainForm.ReqNametoApproveRanorexRT2Info.Exists(30000)&&i<6);
        	}
        }

