        public void CompareTextFiles(string OutputPath, string FormTitle, string ReferencePath, string ReferenceTextFile)
        {
        	
            var file1 = Path.Combine(OutputPath, "references " + FormTitle + ".txt");
            var file2 = Path.Combine(ReferencePath, ReferenceTextFile);
            Report.Log(ReportLevel.Info, "Comparing text files " + file1 + " and " + file2);
            bool filesMatch = compareFiles(file1, file2);
            if (!filesMatch)
            {
                Report.Failure("The text files do not match.");
            }
            else
            {
            	Report.Success("The text files do match.");
            }
        }
        
        private bool compareFiles(string file1, string file2)
        {
            var file1Bytes = File.ReadAllBytes(file1);
            var file2Bytes = File.ReadAllBytes(file2);
            return ArraysEqual(file1Bytes, file2Bytes);
        }
        
        static bool ArraysEqual<T>(T[] a1, T[] a2)
        {
            if (ReferenceEquals(a1, a2))
                return true;

            if (a1 == null || a2 == null)
                return false;

            if (a1.Length != a2.Length)
                return false;

            EqualityComparer<T> comparer = EqualityComparer<T>.Default;
            for (int i = 0; i < a1.Length; i++)
            {
                if (!comparer.Equals(a1[i], a2[i])) return false;
            }
            return true;
        }

    }
