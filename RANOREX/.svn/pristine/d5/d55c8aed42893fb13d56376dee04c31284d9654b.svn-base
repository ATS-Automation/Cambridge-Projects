        public void Validate_Status()
        {
        	int count = 0;
        	
        	if (varInnerText != "D")
        	{
        		if (varInnerText == "E")
        		{
        			Validate.Fail("Error has occured, Job Status of E detected!");
        		}
        		if (varInnerText == "Z")
        		{
        			Validate.Fail("Error has occured default value of Z detected, status not detected");
        		}
        		
        		if (varInnerText == "P" || varInnerText == "W" || varInnerText == "S")
        		{
        			do
        			{
        				Report.Log(ReportLevel.Info, "Innertext value: " + varInnerText + " Waiting 30 seconds and trying again.");
        				Delay.Seconds(30.0);
        				repo.JDEPath.E1menuAppIframe.HcFind.Click();
        				Delay.Milliseconds(2000);
        				repo.JDEPath.E1menuAppIframe.RANOREXRTInfo.WaitForExists(30000);
        				varInnerText = repo.JDEPath.E1menuAppIframe.DivTagD.Element.GetAttributeValueText("InnerText");
        				Delay.Milliseconds(2000);
        				count++;
        			} while (count<20 && (varInnerText == "P" || varInnerText == "W" || varInnerText == "S"));
        		}
        		if (count >= 20)
        		{
        			Validate.Fail ("Status Recheck timed out after 10 minutes, check job in JDE");
        		}	        		
        		
        	}
        	if (varInnerText == "D")
        	{
        		Validate.IsTrue (varInnerText == "D", "Job has successfully completed.");
        	}

        	else
        	{
        		Validate.Fail ("Error: Unknown status of Job");
        	}
        }

    }
