    </wsdl:operation>
    <wsdl:operation name="GetPropertyByAccountIDCurrentContext">
      <soap12:operation soapAction="http://atsportal/GetPropertyByAccountIDCurrentContext" style="document" />
      <wsdl:input>
        <soap12:body use="literal" />
      </wsdl:input>
      <wsdl:output>
