    </wsdl:operation>
    <wsdl:operation name="GetUserDomainName">
      <soap12:operation soapAction="http://atsportal/GetUserDomainName" style="document" />
      <wsdl:input>
        <soap12:body use="literal" />
      </wsdl:input>
      <wsdl:output>
        <soap12:body use="literal" />
      </wsdl:output>
    </wsdl:operation>
  </wsdl:binding>
  <wsdl:service name="ATSGlobalCatalogQuery">
    <wsdl:port name="ATSGlobalCatalogQuerySoap" binding="tns:ATSGlobalCatalogQuerySoap">
      <soap:address location="http://gcwebservice/ATSGlobalCatalogQueryService.asmx" />
    </wsdl:port>
    <wsdl:port name="ATSGlobalCatalogQuerySoap12" binding="tns:ATSGlobalCatalogQuerySoap12">
      <soap12:address location="http://gcwebservice/ATSGlobalCatalogQueryService.asmx" />
    </wsdl:port>
  </wsdl:service>
</wsdl:definitions>