        public void SwitchEnvironment(string Enviro)
        {        	        	
        	if (Enviro == "SwitchtoPLM")        		            
            	repo.SolidWorks2016.TaskPane.Environments.Environment2.Click();
        	else if (Enviro == "SwitchtoDDM")        		            
            	repo.SolidWorks2016.TaskPane.Environments.Environment1.Click();
        	else if (Enviro == "SwitchtoInfor")
        		repo.SolidWorks2016.TaskPane.Environments.Environment3.Click();
        	else        		
        		repo.SolidWorks2016.TaskPane.Environments.SwitchtoEnviro.Click();
        }
    }    
