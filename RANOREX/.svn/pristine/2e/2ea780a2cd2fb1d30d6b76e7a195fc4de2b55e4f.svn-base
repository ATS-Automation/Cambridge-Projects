        public void Validate_AutoCAD_FileExists()
        {
        	int i = 0;
        	try
        	{
        		
        	
        	if (!(File.Exists (DownloadPath + "\\" + varDrawingName + ".dwg")))
        		{
        			do
        			{
        				Delay.Seconds(30);
        				Report.Log(ReportLevel.Info, DownloadPath + "\\" + varDrawingName + ".dwg" + " not found...retrying");
        				i++;
        			}while (!(File.Exists (DownloadPath + "\\" + varDrawingName + ".dwg"))&& i<4);
        			if ((i>=4)&& !(File.Exists (DownloadPath + "\\" + varDrawingName + ".dwg")))
        			{
        				Report.Log(ReportLevel.Error, "AutoCAD drawing not found with in 2 minutes, check GPS");
        			}
        		}
        	if (File.Exists (DownloadPath + "\\" + varDrawingName + ".dwg"))
        	    {
        	    	Report.Log(ReportLevel.Info, "Found AutoCAD drawing in the location: " + DownloadPath + "\\" + varDrawingName + ".dwg");
        	    	System.Diagnostics.Process.Start(DownloadPath + "\\" + varDrawingName + ".dwg");
        	    }
        	}
        	catch (Exception ex)
        	{
        		Report.Log(ReportLevel.Error, "Error occurred: " + ex.Message.ToString());
        	}
        }
    }
