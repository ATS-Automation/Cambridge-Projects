        public void ValidateAllPrices()
        {
        	var priceofFirstItem = repo.ATSStoreLogin.PriceofFirstItem;
        	var orderTotal = repo.ATSStoreLogin.OrderTotal;
        //	var cartTotal = repo.ATSStoreLogin.CartTotal;
        	
        	var priceofFirst = Convert.ToDecimal(priceofFirstItem.InnerText.Substring(1));
        	priceofFirst = priceofFirst * 2;
        	var priceofFirstString = "$" + priceofFirst.ToString();
        	var orderTotalPrice = orderTotal.InnerText;
        //	var cartTotalPrice = cartTotal.InnerText.Substring(cartTotal.InnerText.IndexOf("$"));
        	
        Ranorex.Validate.IsTrue(priceofFirstString == orderTotalPrice, "Checking if Total Price of First Item: " + priceofFirstString + " EQUALS Order Total Price: " + orderTotalPrice + ". The Validation @ValidateRESULT@!");

        }

        public void ValidatePricesAreSame(string argument1, string argument2)
        {
        	Ranorex.Validate.IsTrue(argument1 == argument2, "Checking if Total Price: " + argument1 + " EQUALS Cart Total Price: " + argument2 +".  The Validation @ValidateRESULT@!");
        }

    }
