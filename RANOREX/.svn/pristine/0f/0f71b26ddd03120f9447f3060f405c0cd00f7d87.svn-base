        public void RefreshWoOutcome()
        {
            var startTime = System.DateTime.Now;
            var timeout = TimeSpan.FromMinutes(20);
            
            while (System.DateTime.Now.Subtract(startTime) < timeout)
            {            
	            repo.PLMMainForm.MainSplitPane.WorkOrdersPane.RWO.TabWF.Click("26;12");
	            Delay.Seconds(10.0);
	            repo.PLMMainForm.MainSplitPane.WorkOrdersPane.RWO.TabWOOutcome.Click("26;11");
	            
	            var rowCount = int.Parse(repo.PLMMainForm.MainSplitPane.WorkOrdersPane.RWO.RwoOutcomeTreeTable.Element.GetAttributeValueText("RowCount"));
	            if (rowCount > 1)
	            {
	            	return;
	            }
            }
            
            Report.Failure("Items were not released in the timeout period");
        }

