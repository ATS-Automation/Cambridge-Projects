        public void DeleteHomeFolder(string testFilesPath)
        {
           try
        	{
            	
           	 	if (Directory.Exists(testFilesPath))
            	{
           	 		foreach (var file in new DirectoryInfo(testFilesPath).GetFiles()) 
           	 		{
           	 			File.SetAttributes(file.FullName, FileAttributes.Normal);
            		}
           	 		var dirInfo = new DirectoryInfo(testFilesPath);
           	 		dirInfo.Attributes = FileAttributes.Normal;
           	 		Directory.Delete(testFilesPath, true);
           	 		Report.Info($"Folder: {testFilesPath} successfully deleted");
            	}
           	 	else
	        	{
	        		Report.Info($"Folder: {testFilesPath} doesn't exist, can't delete");
	        	}
            	
            
        	}
        	
        	catch (Exception ex)
        	{
        		Report.Warn(ex.StackTrace.ToString());
        	}
        	
        }

        public string GetHomeFolderPathofUser()
        {
        	var username = System.Environment.UserName.ToLower().Replace("atsna\\","");
        	return @"C:\home\" + username;
        }

        public void OpenAssemblyAndValidateMissingRefs(string HomeFolderPath)
        {
        	if (Directory.Exists(HomeFolderPath))
        	{
        		var dirInfo = new DirectoryInfo(HomeFolderPath);
        		var assemblyFilePath = dirInfo.GetFiles("29635994*.SLDASM");
        		if(assemblyFilePath.Length == 1)
        		{
        			var assemblyName = assemblyFilePath[0].Name;
        			var missingRefs = BTPUserCodeCollection.GetComponentReferences(assemblyFilePath[0].FullName);
        			if (missingRefs.Count > 0)
        			{
        				foreach (var missingref in missingRefs) 
        				{
        					Ranorex.Validate.IsTrue(missingRefs.Count>0, "Missing References found for downloaded assembly: " + assemblyName + " The assembly is missing the following file: " + missingref);
        				}
        			}
        		}
        	}
        }

    }
