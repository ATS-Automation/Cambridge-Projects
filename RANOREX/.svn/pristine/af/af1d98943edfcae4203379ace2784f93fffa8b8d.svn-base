        public void CheckCarousel()
        {
        	Report.Info("Waiting for 10 seconds to see if multiple carousel pages Exist");
        	if (repo.ATSStoreLogin.CarouselIndicatorsInfo.Exists(Duration.FromMilliseconds(10000)))
        	{
        		var listItems = repo.ATSStoreLogin.CarouselIndicators.FindChildren<LiTag>();
        		foreach (var liTag in listItems) 
        		{
        			liTag.Click();
        			Delay.Seconds(1.0);
        			Report.Screenshot(repo.ATSStoreLogin.Carousel);
        		}
        		listItems[0].Click();
        	}
        	else
        	{
        		Report.Info("Only single Carousel page found, taking screenshot");
        		Report.Screenshot(repo.ATSStoreLogin.Carousel);
        	}
        }
    }
